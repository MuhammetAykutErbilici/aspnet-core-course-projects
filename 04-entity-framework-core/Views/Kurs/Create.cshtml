@model Kurs
<h1>Kurs Ekle</h1>
<div asp-validation-summary="All" class="text-danger"></div>
<hr>
<form asp-controller="Kurs" asp-action="Create" method="post">
   <div class="mb-3">
      <label asp-for="Baslik" class="form-label">Kurs Başlığı</label>
      <input asp-for="Baslik" class="form-select" />
   </div>
   <div class="mb-3">
      <label asp-for="OgretmenId" class="form-label">Öğretmen</label> 
      <select asp-for="OgretmenId" asp-items="ViewBag.Ogretmenler" class="form-select">
         <option value="">Seçiniz</option>
      </select>
   </div>
 

   <button type="submit" class="btn btn-secondary">Kaydet</button>
</form>