@model IEnumerable<EntityFramework.Data.KursKayit>
    
    <h2>Kurs Kayıt Listesi</h2>
    <hr>
    <a asp-action="Create" class="btn btn-primary">Kayıt Ekle</a>
    <hr>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th style="width: 150px;">@Html.DisplayNameFor(m => m.KayitId)</th>
                <th>Öğrenci Adı</th>
                <th>Kurs Başlığı</th>
                <th style="width: 150px;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
            <tr>
                <td>@item.KayitId</td>
                <td>@item.Ogrenci?.OgrenciAd @item.Ogrenci?.OgrenciSoyad</td>
                <td>@item.Kurs?.Baslik</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.KayitId" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.KayitId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
            }
        </tbody>
    </table>