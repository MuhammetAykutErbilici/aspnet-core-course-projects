@model IEnumerable<Ogretmen>

    <h1>Öğretmen Listesi</h1>
    <hr>
    <a href="/Ogretmen/Create" class="btn btn-primary">Yeni Öğretmen Ekle</a>
    <hr>
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(m => m.OgretmenId)</th>
                <th>@Html.DisplayNameFor(m => m.Ad)</th>
                <th>@Html.DisplayNameFor(m => m.Soyad)</th>
                <th style="width: 150px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.OgretmenId) </td>
                <td>@Html.DisplayFor(modelItem => item.Ad)</td>
                <td>@Html.DisplayFor(modelItem => item.Soyad)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.OgretmenId"class="btn btn-sm btn-primary">Edit</a> 
                    <a asp-action="Delete" asp-route-id="@item.OgretmenId"class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
            }

        </tbody>
    </table>