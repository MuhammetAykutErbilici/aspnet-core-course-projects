@model UserInfo

@{
ViewBag.Title = "Başvuru Durumu";

}

<main class="text-center">
    <h1 class="h4">Toplantı Özeti</h1>
    @if(Model.WillAttend == true)
    {
    <p>Teşşekürler, @Model.Name Toplantıya sizinle birlikte @ViewBag.UserCount kişi katılıyor</p>
    <a class="btn btn-sm btn-outline-primary" href="/meeting/list">Katılımcıları Listele</a>
    }
    else
    {
    <p class="text-danger">Toplantıya katılamayacağınız için üzgünüz.</p>
    <a class="btn btn-sm btn-outline-primary" href="/meeting/apply">Başvuru Formu</a>
    }
</main>