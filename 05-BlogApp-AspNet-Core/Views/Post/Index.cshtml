@model PostsViewModel

<div class="row">
    <div class="col-lg-8">
        <div class="bg-white p-4 shadow-sm rounded">
            <h1 class="h4 mb-4 fw-bold">Popular Posts</h1>

            @foreach (var post in Model.Posts) {
            <div class="card bg-transparent border-0 mb-3">
                <div class="row g-0 align-items-center">
                    <div class="col-4">

                        <img src="~/img/@post.Image" class="img-fluid rounded" alt="@post.Title">
                    </div>
                    <div class="col-8">
                        <div class="ps-3">
                            <h5>
                                <a href="/posts/@post.Url" class="text-decoration-none text-dark fw-bold hover-primary">
                                    @post.Title
                                </a>
                            </h5>
                            <p class="text-muted small">@post.Content</p>
                            <a href="#" class="badge bg-danger bg-opacity-10 text-danger text-decoration-none mb-2 fw-bold">
                                Web Development
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <hr class="my-3 text-secondary opacity-25"> }


            <nav class="mt-4">
                <ul class="pagination pagination-sm">
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                </ul>
            </nav>
        </div>
    </div>


    <div class="col-lg-4">
        <vc:tags-menu></vc:tags-menu>
        <vc:new-posts></vc:new-posts>
    </div>
</div>