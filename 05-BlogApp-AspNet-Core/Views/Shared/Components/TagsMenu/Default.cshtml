@model List<Tag>

<div class="card mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">Tags</h5>
    </div>
    <div class="card-body">
        <ul class="list-inline mb-0">
            @foreach(var tag in Model) 
            {
                <li class="list-inline-item me-2 mb-2">
                    <a href="/posts/tag/@tag.Url" class="btn btn-outline-secondary btn-sm">@tag.Text</a>
                </li>
            }
        </ul>
    </div>
</div>